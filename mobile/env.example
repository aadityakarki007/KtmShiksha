# Copy to .env in this folder (same keys as web, plus API origin).
# Expo only exposes variables prefixed with EXPO_PUBLIC_.

EXPO_PUBLIC_CLERK_PUBLISHABLE_KEY=
EXPO_PUBLIC_API_BASE_URL=

# APK via EAS cloud build: set the same keys in Expo — Project → Environment variables
# (or `eas env:create`), because gitignored .env is not uploaded to EAS by default.
# See https://docs.expo.dev/eas/environment-variables/
